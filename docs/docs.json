{
  "$schema": "https://mintlify.com/schema.json",
  "name": "SlackHive",
  "theme": "maple",
  "logo": {
    "light": "/logo/wide-light.svg",
    "dark": "/logo/wide-dark.svg"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#D97757"
  },
  "navbar": {
