{
  "name": "slackhive",
  "version": "0.4.8",
  "private": false,
  "description": "Open-source platform for managing teams of Claude Code Slack agents with a boss agent orchestrator",
  "workspaces": [
    "apps/*",
    "packages/*",
    "cli"
  ],
  "bin": {
    "slackhive": "cli/dist/index.js"
  },
  "scripts": {
    "dev": "sh scripts/dev.sh",
    "build": "npm run build -w packages/shared && npm run build --workspaces --if-present",
    "prepare": "npm run build -w cli",
    "postinstall": "node scripts/postinstall.js"
  },
  "files": [
    "cli/dist",
    "README.md",
    "scripts/postinstall.js"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.162",
    "@anthropic-ai/claude-code": "^2.1.118",
    "@elastic/elasticsearch": "^9.3.4",
    "@mozilla/readability": "^0.6.0",
    "linkedom": "^0.18.12",
    "pg": "^8.20.0",
    "turndown": "^7.2.4"
  },
  "overrides": {
    "dompurify": "^3.4.0",
    "vite": "^6.4.2",
    "axios": "^1.16.0",
    "hono": "^4.12.18",
    "@hono/node-server": "^1.19.13",
    "follow-redirects": "^1.15.12",
    "fast-uri": "^3.1.2",
    "ip-address": "^10.2.0",
    "express-rate-limit": "^8.5.1"
  },
  "devDependencies": {
    "@types/turndown": "^5.0.6"
  }
}
