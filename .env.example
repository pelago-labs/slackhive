# ============================================================
# Slack Claude Code Agent Team — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- Database ---
POSTGRES_DB=agentteam
POSTGRES_USER=agentteam
POSTGRES_PASSWORD=change_me_in_production

# For local development without Docker, override:
DATABASE_URL=postgresql://agentteam:agentteam@localhost:5432/agentteam

# --- Redis (used for agent hot-reload pub/sub) ---
REDIS_URL=redis://localhost:6379

# --- Platform ---
PLATFORM_URL=http://localhost:3000
NODE_ENV=development
