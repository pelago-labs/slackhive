# ============================================================
# SlackHive — Environment Configuration
# ============================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in ALL required values marked with <...>
# 3. Never commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# Agent Backend Authentication
# ------------------------------------------------------------
# Preferred: configure the backend (Claude Code or OpenAI Codex) and its
# credentials in the web UI under Settings → Agent Backend. The env vars below
# are optional fallbacks for headless/CI setups.

# Claude Code — Anthropic API key (pay-per-use); or leave unset and use the
# Claude subscription (run `claude login`, or set creds in Settings).
# ANTHROPIC_API_KEY=<sk-ant-api03-...>

# OpenAI Codex — API key (pay-per-use); or leave unset and use the ChatGPT
# subscription (set ~/.codex/auth.json via Settings or `codex login`).
# OPENAI_API_KEY=<sk-...>
# CODEX_API_KEY=<sk-...>

# Optional: reuse a host-installed `codex` binary instead of the bundled one.
# CODEX_PATH=/usr/local/bin/codex

# ------------------------------------------------------------
# Web UI Auth
# ------------------------------------------------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=<strong-random-password>
AUTH_SECRET=<output-of-openssl-rand-hex-32>
ENV_SECRET_KEY=<output-of-openssl-rand-hex-32>

# ------------------------------------------------------------
# Platform
# ------------------------------------------------------------
DATABASE_TYPE=sqlite
NODE_ENV=production

# ------------------------------------------------------------
# Features
# ------------------------------------------------------------
ACTIVITY_DASHBOARD=1
